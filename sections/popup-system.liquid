      "max": 90,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "awareness_delay",
      "label": "Delay before showing (seconds)",
      "min": 0,
      "max": 2,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "awareness_auto_close",
