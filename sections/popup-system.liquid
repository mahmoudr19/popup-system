    {
      "type": "checkbox",
      "id": "conversion_enabled",
      "label": "Enable conversion popup",
      "default": true
    },
    {
      "type": "text",
      "id": "conversion_title",
      "label": "Image alt text",
      "default": "Limited offer"
    },
    {
      "type": "image_picker",
      "id": "conversion_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "conversion_image_url",
      "label": "Image URL (optional)"
    },
    {
      "type": "text",
      "id": "conversion_promo_code",
      "label": "Promo code",
      "default": "FlakeRamadan26"
    },
    {
      "type": "color",
      "id": "conversion_background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "conversion_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "conversion_max_width",
      "label": "Max width (px)",
      "min": 280,
      "max": 720,
      "step": 10,
      "default": 520
    },
    {
      "type": "range",
      "id": "conversion_padding",
      "label": "Padding (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "conversion_border_radius",
      "label": "Border radius (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "conversion_overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55
    },
    {
      "type": "range",
      "id": "conversion_delay",
      "label": "Delay before showing (seconds)",
      "min": 10,
      "max": 600,
      "step": 10,
      "default": 90
